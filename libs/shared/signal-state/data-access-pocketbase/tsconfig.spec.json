{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../../dist/out-tsc",
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["jest", "node"],
    "isolatedModules": true,
    "declaration": true
  },
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ],
  "include": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
