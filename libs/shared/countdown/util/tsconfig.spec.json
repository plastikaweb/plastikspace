{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../../dist/out-tsc",
    "module": "preserve",
    "target": "es2016",
    "types": ["jest", "node"],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "declaration": true,
    "composite": true
  },
  "files": ["src/test-setup.ts"],
  "include": ["jest.config.cts", "src/**/*.test.ts", "src/**/*.spec.ts", "src/**/*.d.ts"]
}
