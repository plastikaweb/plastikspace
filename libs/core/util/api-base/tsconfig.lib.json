{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../../dist/out-tsc",
    "inlineSources": true,
    "declaration": true,
    "composite": true
  },
  "exclude": [
    "src/test-setup.ts",
    "src/**/*.spec.ts",
    "jest.config.ts",
    "src/**/*.test.ts",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/test-setup.ts"
  ],
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../environments/tsconfig.lib.json"
    },
    {
      "path": "../../entities/tsconfig.lib.json"
    },
    {
      "path": "../../../../libs/shared/util/objects/tsconfig.lib.json"
    }
  ]
}
