{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true
  },
  "exclude": [
    "src/**/*.spec.ts",
    "src/test-setup.ts",
    "jest.config.ts",
    "src/**/*.test.ts",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/test-setup.ts"
  ],
  "include": [
    "src/**/*.ts",
    "../../shared/auth/firebase/data-access/src/isLogged.guard.ts",
    "../../shared/auth/firebase/data-access/src/isNotLogged.guard.ts",
    "../../shared/auth/firebase/data-access/src/isAdmin.guard.ts",
    "../order-list/data-access/src/isAnActiveOrderList.guard.ts",
    "../../../util/src/**/*.ts"
  ]
}
