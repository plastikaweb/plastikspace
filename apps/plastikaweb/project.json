{
  "name": "plastikaweb",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/plastikaweb/src",
  "tags": ["scope:plastikaweb", "type:app"],
  "targets": {
    "build": {
      "executor": "@geekvetica/nx-astro:build",
      "options": {},
      "inputs": [
        "production",
        "^production",
        "{projectRoot}/package.json",
        {
          "externalDependencies": ["astro"]
        }
      ],
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "cache": true,
      "dependsOn": ["^build"]
    },
    "dev": {
      "executor": "@geekvetica/nx-astro:dev",
      "options": {
        "port": 4202
      },
      "cache": false
    },
    "preview": {
      "executor": "@geekvetica/nx-astro:preview",
      "options": {
        "port": 4202
      },
      "cache": false,
      "dependsOn": ["build"]
    },
    "check": {
      "executor": "@geekvetica/nx-astro:check",
      "options": {},
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": ["astro", "typescript"]
        }
      ],
      "cache": true,
      "dependsOn": ["sync"]
    },
    "sync": {
      "executor": "@geekvetica/nx-astro:sync",
      "options": {},
      "inputs": [
        "{projectRoot}/src/content/**/*",
        {
          "externalDependencies": ["astro"]
        }
      ],
      "outputs": [],
      "cache": true,
      "metadata": {
        "technologies": ["astro"],
        "description": "Generate TypeScript types for Astro Content Collections and modules (via astro sync)"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/plastikaweb/jest.config.ts",
        "tsConfig": "apps/plastikaweb/tsconfig.spec.json"
      }
    }
  }
}
