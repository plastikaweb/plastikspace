{
  "extends": ["../../.eslintrc.json", "plugin:astro/recommended"],
  "parserOptions": {
    "ecmaVersion": 2015
  },
  "ignorePatterns": ["!**/*", ".astro"],
  "overrides": [
    {
      "files": ["*.mjs", "astro.config.mjs", "vite.config.mjs", "vite.config.*.mjs"],
      "parserOptions": {
        "ecmaVersion": 2015,
        "sourceType": "module"
      }
    },
    {
      "files": ["*.astro"],
      "parser": "astro-eslint-parser",
      "parserOptions": {
        "parser": "@typescript-eslint/parser",
        "extraFileExtensions": [".astro"],
        "project": "apps/plastikaweb/tsconfig.json"
      },
      "rules": {}
    },
    {
      "files": ["*.ts", "*.tsx"],
      "extends": ["plugin:@nx/typescript"],
      "rules": {}
    },
    {
      "files": ["*.js", "*.jsx"],
      "extends": ["plugin:@nx/javascript"],
      "rules": {}
    }
  ]
}
