{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "diffEditor.wordWrap": "inherit",
  "workbench.editor.wrapTabs": false,
  "html.format.wrapAttributes": "force-expand-multiline",
  "files.trimTrailingWhitespace": true,
  "prettier.configPath": "./.prettierrc",
  "prettier.requireConfig": true,
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.js": {
      "when": "$(basename).ts"
    },
    "**/.js.map": {
      "when": "$(basename)"
    }
  },
  "angular.log": "off",
  "angular.enable-strict-mode-prompt": false,
  "nxConsole.nxWorkspacePath": "./",
  "nxConsole.enableCodeLens": true,
  "nxConsole.enableTaskExecutionDryRunOnChange": false,
  "nxConsole.projectViewingStyle": "automatic",
  "angular-schematics.schematicsDefaultOptions": {
    "angular-*": {
      "style": "scss",
      "skipStyle": true
    }
  },
  "editor.formatOnSaveMode": "file",
  "typescript.tsserver.maxTsServerMemory": 4096,
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,
  "eslint.enable": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact", "json"],
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "eslint.lintTask.enable": true,
  "eslint.options": {
    "cache": true,
    "cacheLocation": ".eslintcache"
  },
  "eslint.run": "onSave",
  "css.customData": [".vscode/tailwind.json"],
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.rootFontSize": 15,
  "tailwindCSS.experimental.configFile": "libs/core/styles/util/tailwind4/src/_core_tailwind_theme.css",
  "tailwindCSS.includeLanguages": {
    "scss": "tailwindcss",
    "less": "tailwindcss",
    "css": "tailwindcss",
    "sass": "tailwindcss",
    "html": "tailwindcss"
  },
  "files.associations": {
    "*.css": "tailwindcss",
    "*.scss": "tailwindcss"
  },
  "editor.codeActions.triggerOnFocusChange": false,
  "files.autoSave": "onFocusChange",
  "workbench.colorTheme": "Atom One Dark",
  "editor.codeActionsOnSave": {
    "source.organizeImports": "always"
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/tmp/**": true,
    "**/.nx/cache/**": true,
    "**/.angular/**": true,
    "**/.firebase/**": true,
    "**/.gemini/**": true,
    "**/coverage/**": true,
    "**/pocketbase/pb_data/**": true
  },
  "search.exclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/tmp/**": true,
    "**/.nx/cache/**": true,
    "**/.angular/**": true,
    "**/.firebase/**": true,
    "**/.gemini/**": true,
    "**/coverage/**": true,
    "**/pocketbase/pb_data/**": true
  },
  "jest.disabledWorkspaceFolders": [
    "node_modules",
    "dist",
    "tmp",
    ".nx/cache",
    "vendor",
    "pocketbase",
    "coverage"
  ],
  "jest.runMode": "on-demand",
  "githubIssues.alwaysPromptForNewIssueRepo": true,
  "githubPullRequests.remotes": ["origin", "upstream", ""],
  "githubPullRequests.showPullRequestNumberInTree": true,
  "githubIssues.queries": [
    {
      "label": "Botiga Eco (Projecte)",
      "query": "repo:plastikaweb/plastikspace is:open project:plastikaweb/5"
    }
  ],
  "editor.formatOnSave": true,
  "astro.updateImportsOnFileMove.enabled": true,
  "javascript.updateImportsOnPaste.enabled": true,
  "typescript.updateImportsOnPaste.enabled": true,
  "workbench.productIconTheme": "material-product-icons",
  "workbench.preferredDarkColorTheme": "Atom One Dark",
  "workbench.preferredHighContrastLightColorTheme": "Monokai Dimmed",
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[scss]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "workbench.fontAliasing": "antialiased",
  "terminal.integrated.lineHeight": 0,
  "terminal.integrated.letterSpacing": 1,
  "terminal.integrated.smoothScrolling": false,
  "editor.fontFamily": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
  "i18n-ally.localesPaths": ["apps/eco-store/public/i18n"],
  "i18n-ally.keystyle": "nested",
  "markdownlint.configFile": "./.markdownlint-cli2.yaml",
  "markdownlint.run": "onSave",
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.fontSize": 13,
  "diffEditor.experimental.useTrueInlineView": false,
  "debug.console.fontSize": 13,
  "terminal.integrated.fontSize": 12,
  "markdown.preview.fontSize": 13,
  "i18n-ally.sourceLanguage": "ca"
}
