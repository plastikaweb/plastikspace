{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "diffEditor.wordWrap": "inherit",
  "workbench.editor.wrapTabs": false,
  "html.format.wrapAttributes": "force-expand-multiline",
  "files.trimTrailingWhitespace": true,
  "prettier.configPath": "./.prettierrc",
  "prettier.requireConfig": true,
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "never"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
      "editor.formatOnSave": true,
      "editor.codeActionsOnSave": {
        "source.organizeImports": "never",
        "source.fixAll.eslint": "never"
      }
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.js": {
      "when": "$(basename).ts"
    },
    "**/.js.map": {
      "when": "$(basename)"
    }
  },
  "angular.log": "off",
  "angular.enable-strict-mode-prompt": false,
  "nxConsole.nxWorkspacePath": "./",
  "nxConsole.enableCodeLens": true,
  "nxConsole.projectViewingStyle": "automatic",
  "angular-schematics.schematicsDefaultOptions": {
    "angular-*": {
      "style": "scss",
      "skipStyle": true
    }
  },
  "editor.formatOnSaveMode": "file",
  "typescript.tsserver.maxTsServerMemory": 4096,
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,
  "eslint.enable": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact", "json"],
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "eslint.lintTask.enable": true,
  "eslint.options": {
    "cache": true,
    "cacheLocation": ".eslintcache"
  },
  "eslint.run": "onType",
  "markdownlint.configFile": "./.markdownlint.json",
  "markdownlint.lintWorkspaceGlobs": [
    "**/*.md",
    "!**/pocketbase/**/*.md",
    "!**/*.code-search",
    "!**/bower_components/**",
    "!**/node_modules/**",
    "!**/.git/**",
    "!**/vendor/**"
  ],
  "markdownlint.run": "onSave",
  "css.customData": [".vscode/tailwind.json"],
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.rootFontSize": 15,
  "editor.codeActions.triggerOnFocusChange": false,
  "files.autoSave": "onFocusChange",
  "workbench.colorTheme": "One Dark Pro",
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll.eslint": "explicit"
  }
}
