{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "diffEditor.wordWrap": "inherit",
  "workbench.editor.wrapTabs": false,
  "html.format.wrapAttributes": "force-expand-multiline",
  "files.trimTrailingWhitespace": true,
  "prettier.configPath": "./.prettierrc",
  "prettier.requireConfig": true,
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[scss]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html][json]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.js": {
      "when": "$(basename).ts"
    },
    "**/.js.map": {
      "when": "$(basename)"
    }
  },
  "angular.log": "verbose",
  "nxConsole.nxWorkspacePath": "./",
  "nxConsole.enableCodeLens": true,
  "nxConsole.projectViewingStyle": "automatic",
  "angular-schematics.schematicsDefaultOptions": {
    "angular-*": {
      "style": "scss",
      "skipStyle": true
    }
  },
  "editor.formatOnSaveMode": "file",
  "eslint.enable": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "json"
  ],
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "eslint.lintTask.enable": true,
  "eslint.run": "onType",
  "markdownlint.configFile": "./.markdownlint.json",
  "markdownlint.lintWorkspaceGlobs": [
    "**/*.md",
    "!**/pocketbase/**/*.md",
    "!**/*.code-search",
    "!**/bower_components/**",
    "!**/node_modules/**",
    "!**/.git/**",
    "!**/vendor/**"
  ],
  "markdownlint.run": "onSave",
  "css.customData": [".vscode/tailwind.json"],
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.rootFontSize": 15
}
