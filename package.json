    "cz-customizable": "^7.2.1",
    "cz-customizable-ghooks": "^2.0.0",
    "esbuild": "^0.19.2",
    "eslint": "~8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-cypress": "^3.5.0",
    "eslint-plugin-deprecation": "^1.5.0",
    "eslint-plugin-jsdoc": "^61.4.1",
