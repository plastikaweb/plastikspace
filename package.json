{
  "name": "plastikspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "ng": "nx",
    "postinstall": "node ./decorate-angular-cli.js",
    "start": "nx serve",
    "stop": "kill -9 $(lsof -t -i:4200)",
    "build": "nx run-many --target=build --all --parallel",
    "test": "nx test",
    "test:watch": "nx test --watch",
    "test:coverage": "nx test --coverage",
    "test:all": "nx run-many --all --target=test --ci --passWithNoTests --parallel --max-parallel=3 --run-in-band --code-coverage",
    "test:ci": "nx affected --target=test --base=remotes/origin/develop --parallel",
    "lint": "nx lint",
    "lint:all": "nx run-many --all --target=lint --parallel --max-parallel=3",
    "lint:ci": "nx affected --target=lint --base=remotes/origin/develop --head=HEAD --parallel",
    "i18n:validate": "node tools/scripts/validate-i18n-keys.js",
    "i18n:test": "bash tools/scripts/test-i18n-validation.sh",
    "e2e:all": "nx run-many --all --target=e2e --headed=false --watch=false",
    "e2e:ci": "nx affected --target=e2e --base=remotes/origin/develop --parallel --headed=false --watch=false",
    "affected:apps": "nx affected:apps",
    "affected:libs": "nx affected:libs",
    "affected:build": "nx affected:build --configuration=production",
    "affected:e2e": "nx affected:e2e --port='cypress-auto'",
    "affected:e2e:watch": "nx affected:e2e --watch",
    "affected:test": "nx affected:test --parallel --max-parallel=3 --run-in-band",
    "affected:lint": "nx affected:lint --parallel --max-parallel=3 --verbose --cache",
    "affected:dep-graph": "nx affected:dep-graph",
    "format:write": "nx format:write",
    "format:check": "nx format:check",
    "update": "nx migrate latest",
    "workspace-generator": "nx workspace-generator",
    "dep-graph": "nx dep-graph",
    "help": "nx help",
    "husky-install": "npx husky",
    "clean": "rimraf node_modules",
    "clean:all": "rm -rf node_modules dist && yarn cache clean",
    "clean:dist": "rimraf dist",
    "install:local": "yarn husky-install && yarn clean:all && yarn install --immutable",
    "markdownlint": "markdownlint-cli2",
    "branch:lint": "branch-name-lint branchNameLint.json",
    "nasa-images:serve": "nx run nasa-images:serve",
    "nasa-images:lint": "nx run nasa-images:lint",
    "nasa-images:build": "nx run nasa-images:build --parallel",
    "nasa-images:test": "nx run nasa-images:test",
    "nasa-images:e2e": "nx run nasa-images-e2e:e2e",
    "nasa-images:e2e:local": "yarn nx run nasa-images-e2e:e2e --browser=chrome --port='cypress-auto' --watch=true",
    "nasa-images:e2e:ci": "yarn nx run nasa-images-e2e:e2e --port='cypress-auto' --record=true",
    "nasa-images:http-server": "angular-http-server --path ./dist/apps/nasa-images/browser --port 8080",
    "prenasa-images:a11y": "yarn nasa-images:build",
    "nasa-images:a11y:run": "pa11y-ci --config ./apps/nasa-images/.pa11yci.json",
    "nasa-images:a11y": "npm-run-all --parallel --race nasa-images:http-server nasa-images:a11y:run",
    "nasa-images:build:github": "nx run nasa-images:build:prod",
    "llecoop:serve": "firebase use default && nx run llecoop:serve",
    "llecoop:serve:prod": "firebase use production && nx run llecoop:serve --configuration=production",
    "llecoop:serve:staging": "firebase use default && nx run llecoop:serve --configuration=staging",
    "llecoop:lint": "nx run llecoop:lint",
    "llecoop:build": "nx run llecoop:build --parallel",
    "llecoop:test": "nx run llecoop:test",
    "llecoop:e2e": "nx run llecoop-e2e:e2e",
    "llecoop:e2e:local": "yarn nx run llecoop-e2e:e2e --browser=chrome --port='cypress-auto' --watch=true",
    "llecoop:e2e:ci": "yarn nx run llecoop-e2e:e2e --port='cypress-auto' --record=true",
    "llecoop:http-server": "angular-http-server --path ./dist/apps/llecoop/browser --port 8080",
    "prellecoop:a11y": "yarn llecoop:build",
    "llecoop:a11y:run": "pa11y-ci --config ./apps/llecoop/.pa11yci.json",
    "llecoop:a11y": "npm-run-all --parallel --race llecoop:http-server llecoop:a11y:run",
    "llecoop:build:github": "nx run llecoop:build:prod",
    "llecoop:firestore": "firebase emulators:start --only firestore",
    "llecoop:functions": "firebase emulators:start --only functions",
    "llecoop:emulate": "yarn nx run llecoop-firebase:emulate",
    "llecoop:local": "firebase use default && npm-run-all --parallel --race llecoop:emulate llecoop:serve",
    "llecoop:local:staging": "firebase use default && npm-run-all --parallel --race llecoop:emulate llecoop:serve:staging",
    "llecoop:local:prod": "npm-run-all --parallel --race llecoop:emulate llecoop:serve --configuration=production",
    "llecoop:firebase:functions:build": "nx build llecoop-triggers",
    "llecoop:firebase:functions:deploy:staging": "firebase use default && firebase deploy --only functions",
    "llecoop:firebase:functions:deploy:prod": "firebase use production && firebase deploy --only functions",
    "llecoop:deploy:functions": "yarn llecoop:firebase:functions:build && yarn llecoop:firebase:functions:deploy:staging && yarn llecoop:firebase:functions:deploy:prod",
    "llecoop:firebase:firestore:rules:deploy:staging": "firebase use default && firebase deploy --only firestore:rules",
    "llecoop:firebase:firestore:rules:deploy:prod": "firebase use production && firebase deploy --only firestore:rules",
    "llecoop:deploy:firestore:rules": "yarn llecoop:firebase:firestore:rules:deploy:staging && yarn llecoop:firebase:firestore:rules:deploy:prod",
    "llecoop:firebase:storage:deploy:staging": "firebase use default && firebase deploy --only storage",
    "llecoop:firebase:storage:deploy:prod": "firebase use production && firebase deploy --only storage",
    "llecoop:deploy:storage": "yarn llecoop:firebase:storage:deploy:staging && yarn llecoop:firebase:storage:deploy:prod",
    "llecoop:explore": "source-map-explorer dist/apps/llecoop/browser/**/*.js",
    "plastikaweb:serve": "nx run plastikaweb:serve",
    "plastikaweb:lint": "nx run plastikaweb:lint",
    "plastikaweb:build": "nx run plastikaweb:build --parallel",
    "plastikaweb:test": "nx run plastikaweb:test",
    "plastikaweb:e2e": "nx run plastikaweb-e2e:e2e",
    "plastikaweb:e2e:local": "yarn nx run plastikaweb-e2e:e2e --browser=firefox --port='cypress-auto' --watch=true",
    "plastikaweb:http-server": "angular-http-server --path ./dist/apps/plastikaweb/browser --port 8080",
    "preplastikaweb:a11y": "yarn plastikaweb:build",
    "plastikaweb:a11y": "npm-run-all --parallel --race plastikaweb:http-server plastikaweb:a11y:run",
    "plastikaweb:a11y:run": "pa11y-ci --config ./apps/plastikaweb/.pa11yci.json",
    "plastikaweb:build:github": "nx run plastikaweb:build:prod",
    "plastikaweb:codegen": "npx nx codegen plastikaweb-graphql-models",
    "eco-store:pocketbase:run": "cd apps/eco-store/pocketbase && ./pocketbase serve",
    "eco-store:pocketbase:stop": "pkill -f 'pocketbase serve' || true",
    "eco-store:watch-scss": "chokidar 'apps/eco-store/src/styles/_*.scss' -c 'touch apps/eco-store/src/styles/styles.scss'",
    "eco-store:serve": "nx run eco-store:serve",
    "eco-store:serve:staging": "nx run eco-store:serve:staging",
    "eco-store:serve:prod": "nx run eco-store:serve:production",
    "eco-store:local": "yarn eco-store:pocketbase:stop && kill-port 4200 && npm-run-all --parallel --race eco-store:pocketbase:run eco-store:serve eco-store:watch-scss",
    "eco-store:local:staging": "yarn eco-store:pocketbase:stop && kill-port 4200 && npm-run-all --parallel --race eco-store:pocketbase:run eco-store:serve:staging eco-store:watch-scss",
    "eco-store:local:prod": "yarn eco-store:pocketbase:stop && kill-port 4200 && npm-run-all --parallel --race eco-store:pocketbase:run eco-store:serve:prod eco-store:watch-scss",
    "eco-store:lint": "nx run eco-store:lint",
    "eco-store:build": "nx run eco-store:build --parallel",
    "eco-store:build:staging": "nx run eco-store:build:staging",
    "eco-store:build:prod": "nx run eco-store:build:production",
    "eco-store:build-cf": "nx run eco-store:build-cf",
    "eco-store:build-cf:staging": "nx run eco-store:build-cf:staging",
    "eco-store:build-cf:prod": "nx run eco-store:build-cf:production",
    "eco-store:test": "nx run eco-store:test",
    "eco-store:e2e": "nx run eco-store-e2e:e2e",
    "eco-store:e2e:local": "yarn nx run eco-store-e2e:e2e --browser=chrome --port='cypress-auto' --watch=true",
    "eco-store:http-server": "angular-http-server --path ./dist/apps/eco-store/browser --port 8080",
    "preeco-store:a11y": "yarn eco-store:build",
    "eco-store:a11y": "npm-run-all --parallel --race eco-store:http-server eco-store:a11y:run",
    "eco-store:a11y:run": "pa11y-ci --config ./apps/eco-store/.pa11yci.json",
    "eco-store:build:github": "nx run eco-store:build:prod",
    "pb:export": "node apps/eco-store/scripts/export-pocketbase-schema.js",
    "pb:sync": "node apps/eco-store/scripts/sync-pocketbase-schema.js",
    "pb:diff": "git diff apps/eco-store/pocketbase/pb_schema.json"
  },
