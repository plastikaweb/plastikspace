    "@ngrx/operators": "20.1.0",
    "@ngrx/router-store": "20.1.0",
    "@ngrx/signals": "20.1.0",
    "@ngrx/store": "20.1.0",
    "@ngx-formly/core": "^7.0.0",
    "@ngx-formly/material": "^7.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@nx/angular": "22.1.0",
    "@tailwindcss/postcss": "^4.1.16",
    "angular-svg-icon": "^19.0.1",
    "apollo-angular": "^10.0.3",
    "babel-loader": "^9.2.1",
    "date-fns": "3.6.0",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^5.1.1",
    "graphql": "^16.10.0",
    "ngx-colors": "^3.6.0",
    "pocketbase": "^0.26.3",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.8",
    "@angular-devkit/core": "20.3.8",
