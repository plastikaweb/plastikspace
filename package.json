  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": ".cz-config.js"
    }
  },
  "nx": {
    "name": "plastikspace",
    "metadata": {
      "description": "Plastikspace is a monorepo for Plastikaweb Carlos Matheu projects"
    },
    "projectType": "workspace",
    "includedScripts": []
  }
