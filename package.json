    "jest-util": "^29.7.0",
    "jsonc-eslint-parser": "^2.1.0",
    "kill-port": "^2.0.1",
    "markdownlint": "^0.31.0",
    "markdownlint-cli": "^0.36.0",
    "ng-packagr": "20.3.0",
    "npm-run-all": "^4.1.5",
    "nx": "22.1.0",
    "pa11y-ci": "^3.1.0",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.1",
    "source-map-explorer": "^2.5.3",
    "ts-jest": "29.4.5",
    "ts-node": "10.9.1",
    "typescript": "5.9.3",
    "verdaccio": "^6.0.5",
    "zone.js": "~0.15.0"
