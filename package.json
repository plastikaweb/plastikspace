    "@graphql-codegen/typescript-operations": "^4.6.0",
    "@jscutlery/cypress-harness": "^0.7.22",
    "@ngrx/schematics": "20.1.0",
    "@ngrx/store-devtools": "20.1.0",
    "@ngx-formly/schematics": "^7.0.0",
    "@nrwl/cli": "15.9.3",
    "@nrwl/nx-cloud": "19.1.0",
    "@nx/cypress": "22.1.0",
    "@nx/esbuild": "22.1.0",
    "@nx/eslint": "22.1.0",
    "@nx/eslint-plugin": "22.1.0",
    "@nx/jest": "22.1.0",
    "@nx/js": "22.1.0",
    "@nx/node": "22.1.0",
    "@nx/powerpack-license": "^1.2.5",
    "@nx/web": "22.1.0",
    "@nx/workspace": "22.1.0",
    "@schematics/angular": "20.3.8",
